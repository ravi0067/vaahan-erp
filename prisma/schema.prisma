generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Tenant {
  id                 String            @id @default(cuid())
  name               String
  slug               String            @unique
  plan               TenantPlan        @default(FREE)
  status             TenantStatus      @default(ACTIVE)
  subscriptionExpiry DateTime?
  dealershipType     String?
  address            String?
  phone              String?
  email              String?
  gst                String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  bookings           Booking[]
  cashTransactions   CashTransaction[]
  communicationLogs  CommunicationLog[]
  customers          Customer[]
  daybookEntries     DaybookEntry[]
  dealershipBrands   DealershipBrand[]
  expenses           Expense[]
  expenseBudgets     ExpenseBudget[]
  jobCards           JobCard[]
  leads              Lead[]
  permissions        Permission[]
  promotions         Promotion[]
  users              User[]
  vehicles           Vehicle[]
}

model User {
  id               String         @id @default(cuid())
  tenantId         String
  name             String
  email            String         @unique
  password         String
  phone            String?
  role             Role           @default(VIEWER)
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  salesBookings    Booking[]      @relation("SalesExec")
  lockedDaybooks   DaybookEntry[] @relation("LockedBy")
  approvedExpenses Expense[]      @relation("ApprovedBy")
  mechanicJobCards JobCard[]      @relation("Mechanic")
  assignedLeads    Lead[]         @relation("AssignedLeads")
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([email])
  @@index([tenantId], map: "idx_user_tenant")
}

model Permission {
  id        String  @id @default(cuid())
  tenantId  String
  roleType  Role
  module    String
  canView   Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)
  canExport Boolean @default(false)
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, roleType, module])
  @@index([tenantId])
  @@index([tenantId], map: "idx_permission_tenant")
}

model Lead {
  id                   String     @id @default(cuid())
  tenantId             String
  customerName         String
  mobile               String
  email                String?
  interestedModel      String?
  location             String?
  source               String?
  status               LeadStatus @default(NEW)
  dealHealth           DealHealth @default(WARM)
  followUpDate         DateTime?
  assignedToId         String?
  notes                String?
  convertedToBookingId String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  assignedTo           User?      @relation("AssignedLeads", fields: [assignedToId], references: [id])
  convertedToBooking   Booking?   @relation("ConvertedFromLead", fields: [convertedToBookingId], references: [id])
  tenant               Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([assignedToId])
  @@index([tenantId], map: "idx_lead_tenant")
}

model Vehicle {
  id           String        @id @default(cuid())
  tenantId     String
  brandId      String?
  model        String
  variant      String?
  color        String?
  engineNo     String?
  chassisNo    String?       @unique
  price        Decimal       @db.Decimal(12, 2)
  status       VehicleStatus @default(AVAILABLE)
  purchaseDate DateTime?
  supplierId   String?
  createdAt    DateTime      @default(now())
  bookings     Booking[]
  brand        DealershipBrand? @relation("BrandVehicles", fields: [brandId], references: [id])
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([tenantId], map: "idx_vehicle_tenant")
}

model Customer {
  id        String    @id @default(cuid())
  tenantId  String
  name      String
  mobile    String
  email     String?
  address   String?
  aadharNo  String?
  panNo     String?
  createdAt DateTime  @default(now())
  bookings  Booking[]
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([mobile])
  @@index([tenantId], map: "idx_customer_tenant")
}

model Booking {
  id              String            @id @default(cuid())
  tenantId        String
  bookingNumber   String            @unique @default(cuid())
  customerId      String
  vehicleId       String?
  salesExecId     String?
  status          BookingStatus     @default(DRAFT)
  step            Int               @default(1)
  totalAmount     Decimal           @default(0) @db.Decimal(12, 2)
  paidAmount      Decimal           @default(0) @db.Decimal(12, 2)
  pendingAmount   Decimal           @default(0) @db.Decimal(12, 2)
  financeProvider String?
  loanAmount      Decimal?          @db.Decimal(12, 2)
  loanStatus      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  customer        Customer          @relation(fields: [customerId], references: [id])
  salesExec       User?             @relation("SalesExec", fields: [salesExecId], references: [id])
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle         Vehicle?          @relation(fields: [vehicleId], references: [id])
  documents       BookingDocument[]
  payments        BookingPayment[]
  convertedLeads  Lead[]            @relation("ConvertedFromLead")
  rtoRegistration RTORegistration?

  @@index([tenantId])
  @@index([status])
  @@index([bookingNumber])
  @@index([tenantId], map: "idx_booking_tenant")
}

model BookingPayment {
  id         String      @id @default(cuid())
  bookingId  String
  amount     Decimal     @db.Decimal(12, 2)
  mode       PaymentMode
  reference  String?
  receivedBy String?
  date       DateTime    @default(now())
  notes      String?
  booking    Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([bookingId], map: "idx_bookingpayment_booking")
}

model BookingDocument {
  id         String       @id @default(cuid())
  bookingId  String
  type       DocumentType
  fileUrl    String
  fileName   String?
  uploadedAt DateTime     @default(now())
  booking    Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model RTORegistration {
  id                 String    @id @default(cuid())
  bookingId          String    @unique
  registrationNumber String?
  status             RTOStatus @default(APPLIED)
  appliedDate        DateTime  @default(now())
  approvedDate       DateTime?
  insuranceExpiry    DateTime?
  notes              String?
  booking            Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model DaybookEntry {
  id             String            @id @default(cuid())
  tenantId       String
  date           DateTime          @db.Date
  openingBalance Decimal           @default(0) @db.Decimal(14, 2)
  closingBalance Decimal           @default(0) @db.Decimal(14, 2)
  physicalCash   Decimal           @default(0) @db.Decimal(14, 2)
  difference     Decimal           @default(0) @db.Decimal(14, 2)
  isLocked       Boolean           @default(false)
  lockedById     String?
  lockedAt       DateTime?
  createdAt      DateTime          @default(now())
  transactions   CashTransaction[]
  lockedBy       User?             @relation("LockedBy", fields: [lockedById], references: [id])
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@index([tenantId])
  @@index([tenantId], map: "idx_daybook_tenant")
}

model CashTransaction {
  id             String          @id @default(cuid())
  tenantId       String
  daybookEntryId String?
  type           TransactionType
  category       String
  description    String?
  amount         Decimal         @db.Decimal(14, 2)
  mode           String?
  reference      String?
  createdAt      DateTime        @default(now())
  daybookEntry   DaybookEntry?   @relation(fields: [daybookEntryId], references: [id])
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([daybookEntryId])
}

model Expense {
  id           String   @id @default(cuid())
  tenantId     String
  amount       Decimal  @db.Decimal(12, 2)
  category     String
  description  String?
  location     String?
  department   String?
  date         DateTime @default(now())
  approvedById String?
  receiptUrl   String?
  createdAt    DateTime @default(now())
  approvedBy   User?    @relation("ApprovedBy", fields: [approvedById], references: [id])
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId], map: "idx_expense_tenant")
}

model ExpenseBudget {
  id           String  @id @default(cuid())
  tenantId     String
  category     String
  department   String?
  monthlyLimit Decimal @db.Decimal(12, 2)
  month        Int
  year         Int
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, category, department, month, year])
  @@index([tenantId])
}

model JobCard {
  id             String        @id @default(cuid())
  tenantId       String
  vehicleRegNo   String
  customerName   String
  customerMobile String
  complaints     String?
  diagnosis      String?
  partsUsed      Json?
  labourCharge   Decimal       @default(0) @db.Decimal(12, 2)
  partsCharge    Decimal       @default(0) @db.Decimal(12, 2)
  totalBilled    Decimal       @default(0) @db.Decimal(12, 2)
  totalReceived  Decimal       @default(0) @db.Decimal(12, 2)
  pendingAmount  Decimal       @default(0) @db.Decimal(12, 2)
  status         JobCardStatus @default(OPEN)
  mechanicId     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  mechanic       User?         @relation("Mechanic", fields: [mechanicId], references: [id])
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([tenantId], map: "idx_jobcard_tenant")
}

model DealershipBrand {
  id                 String             @id @default(cuid())
  tenantId           String
  brandName          String
  brandType          String             @default("BIKE")
  logoUrl            String?
  createdAt          DateTime           @default(now())
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  showroomLocations  ShowroomLocation[]
  vehicles           Vehicle[]          @relation("BrandVehicles")

  @@index([tenantId])
}

model ShowroomLocation {
  id           String           @id @default(cuid())
  tenantId     String?
  brandId      String
  locationName String
  address      String?
  city         String?
  state        String?
  phone        String?
  managerName  String?
  createdAt    DateTime         @default(now())
  brand        DealershipBrand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
}

model Promotion {
  id                 String   @id @default(cuid())
  tenantId           String
  title              String
  description        String?
  discountPercent    Float    @default(0)
  validFrom          DateTime
  validTo            DateTime
  applicableBrands   String?
  applicableVehicles String?
  type               String   @default("Festival")
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model CommunicationLog {
  id            String    @id @default(cuid())
  tenantId      String
  customerName  String
  phone         String?
  channel       String    @default("call")
  purpose       String?
  status        String    @default("Scheduled")
  scheduledAt   DateTime?
  completedAt   DateTime?
  notes         String?
  direction     String    @default("outbound")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
}

enum Role {
  SUPER_ADMIN
  OWNER
  MANAGER
  SALES_EXEC
  ACCOUNTANT
  MECHANIC
  VIEWER
}

enum TenantPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum LeadStatus {
  NEW
  CONTACTED
  FOLLOWUP
  CONVERTED
  LOST
}

enum DealHealth {
  HOT
  WARM
  COLD
}

enum VehicleStatus {
  AVAILABLE
  BOOKED
  SOLD
  IN_TRANSIT
}

enum BookingStatus {
  DRAFT
  CONFIRMED
  RTO_PENDING
  READY
  DELIVERED
  CANCELLED
}

enum PaymentMode {
  CASH
  UPI
  NEFT
  BANK_TRANSFER
  LOAN
}

enum DocumentType {
  AADHAR
  PAN
  FORM20
  FORM21
  FORM22
  INVOICE
  INSURANCE
  OTHER
}

enum RTOStatus {
  APPLIED
  PENDING
  APPROVED
}

enum TransactionType {
  INFLOW
  OUTFLOW
}

enum JobCardStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  INVOICED
}
