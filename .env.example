# ── Supabase ──────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Database (Prisma) ──────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → Database → Connection string
# Use the "Transaction" mode URL for DATABASE_URL (port 6543, pgbouncer=true)
# Use the "Session" mode URL for DIRECT_DATABASE_URL (port 5432)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ── NextAuth ───────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_minimum_32_characters
NEXTAUTH_URL=https://your-app.vercel.app

# ── Email SMTP (Hostinger) ────────────────────────────────────────────────
# support@yourdomain.com → Customer support, general inquiries, lead notifications
EMAIL_SUPPORT_USER=support@yourdomain.com
EMAIL_SUPPORT_PASSWORD=your_support_email_password

# admin@yourdomain.com → Admin notifications, billing, invoices, internal alerts
EMAIL_ADMIN_USER=admin@yourdomain.com
EMAIL_ADMIN_PASSWORD=your_admin_email_password

# info@yourdomain.com → Marketing, newsletters, general info, auto-replies
EMAIL_INFO_USER=info@yourdomain.com
EMAIL_INFO_PASSWORD=your_info_email_password

# ── WhatsApp Cloud API (Meta) ────────────────────────────────────────────
# Get these from: Meta Business → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_custom_webhook_verify_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id

# ── Webhook & Cron Secrets ────────────────────────────────────────────────
# Use a strong random string for each — e.g. openssl rand -hex 32
EMAIL_WEBHOOK_SECRET=your_email_webhook_secret
CRON_SECRET=your_cron_secret

# ── Default Tenant ────────────────────────────────────────────────────────
# The cuid() ID of the default tenant in your database
DEFAULT_TENANT_ID=your_default_tenant_id
